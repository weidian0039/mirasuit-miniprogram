/* MIRASUIT — Global Styles */
/* ======================== */

/* Brand Variables */
page {
  --brand-black: #1a1a1a;
  --brand-gray: #666666;
  --brand-light-gray: #999999;
  --brand-border: #e8e8e8;
  --brand-bg: #fafafa;
  --brand-card: #ffffff;
  --brand-radius: 8px;
  --brand-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);

  background-color: var(--brand-bg);
  color: var(--brand-black);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* Typography */
.text-title {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--brand-black);
  letter-spacing: 1rpx;
}

.text-subtitle {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--brand-gray);
  line-height: 1.5;
}

.text-caption {
  font-size: 22rpx;
  color: var(--brand-light-gray);
  font-weight: 300;
}

.text-brand {
  font-size: 48rpx;
  font-weight: 200;
  letter-spacing: 8rpx;
  color: var(--brand-black);
}

/* Cards */
.card {
  background: var(--brand-card);
  border-radius: var(--brand-radius);
  padding: 48rpx 32rpx;
  margin: 24rpx;
  box-shadow: var(--brand-shadow);
}

.card-question {
  background: var(--brand-card);
  border-radius: var(--brand-radius);
  padding: 40rpx 32rpx;
  margin: 24rpx;
  box-shadow: var(--brand-shadow);
  transition: transform 0.2s, box-shadow 0.2s;
}

.card-question:active {
  transform: scale(0.98);
  box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
}

/* Buttons */
.btn-primary {
  display: block;
  width: 100%;
  padding: 32rpx 48rpx;
  background: var(--brand-black);
  color: #ffffff;
  border: none;
  border-radius: var(--brand-radius);
  font-size: 30rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
  text-align: center;
  line-height: 1;
}

.btn-primary::after { border: none; }

.btn-secondary {
  display: block;
  width: 100%;
  padding: 28rpx 48rpx;
  background: transparent;
  color: var(--brand-gray);
  border: 1rpx solid var(--brand-border);
  border-radius: var(--brand-radius);
  font-size: 28rpx;
  font-weight: 300;
  text-align: center;
  line-height: 1;
  margin-top: 24rpx;
}

.btn-secondary::after { border: none; }

/* Progress */
.progress-bar {
  width: 100%;
  height: 6rpx;
  background: var(--brand-border);
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 48rpx;
}

.progress-fill {
  height: 100%;
  background: var(--brand-black);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

/* Divider */
.divider {
  width: 80rpx;
  height: 2rpx;
  background: var(--brand-border);
  margin: 48rpx auto;
}

/* MBTI Badge */
.mbti-badge {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--brand-bg);
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--brand-black);
  letter-spacing: 4rpx;
  border: 1rpx solid var(--brand-border);
}

/* Style Card */
.style-card {
  background: linear-gradient(135deg, #1a1a1a 0%, #3a3a3a 100%);
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  margin: 24rpx;
  color: #ffffff;
  position: relative;
  overflow: hidden;
}

.style-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
}

/* Option chips */
.option-chip {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: var(--brand-bg);
  border: 1rpx solid var(--brand-border);
  border-radius: var(--brand-radius);
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: var(--brand-black);
  transition: all 0.2s;
}

.option-chip.selected {
  background: var(--brand-black);
  color: #ffffff;
  border-color: var(--brand-black);
}

.option-chip:active {
  opacity: 0.8;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--brand-black);
  border-radius: 50%;
  animation: pulse 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
.loading-dot:nth-child(3) { animation-delay: 0s; }

@keyframes pulse {
  0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* Safe area */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
