<!--questionnaire.wxml-->
<view class="container">
  <!-- Header -->
  <view class="header">
    <text class="title">Your Style Journey</text>
    <text class="subtitle">Each answer brings us closer to understanding your wardrobe philosophy</text>
    <view class="progress">
      <text class="progress-text">Question {{currentIndex + 1}} of {{totalQuestions}}</text>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
    </view>
  </view>

  <!-- Question Card -->
  <view class="question-card" wx:if="{{currentQuestion}}">
    <text class="question-context" wx:if="{{currentQuestion.context}}">{{currentQuestion.context}}</text>
    <text class="question-text">{{currentQuestion.question}}</text>

    <!-- Options -->
    <view class="options">
      <view
        class="option {{responses[category] && responses[category].text === option.text ? 'selected' : ''}}"
        wx:for="{{currentQuestion.options}}"
        wx:for-item="option"
        wx:key="text"
        bindtap="onOptionSelect"
        data-option="{{option}}"
      >
        <view class="option-radio">
          <view class="radio-dot" wx:if="{{responses[category] && responses[category].text === option.text}}"></view>
        </view>
        <text class="option-text">{{option.text}}</text>
      </view>
    </view>
  </view>

  <!-- Navigation -->
  <view class="navigation">
    <button
      class="nav-btn prev-btn {{currentIndex === 0 ? 'disabled' : ''}}"
      bindtap="onPrevQuestion"
      disabled="{{currentIndex === 0}}"
    >
      Back
    </button>
    <button
      class="nav-btn next-btn {{!hasAnswered ? 'disabled' : ''}}"
      bindtap="onNextQuestion"
      disabled="{{!hasAnswered}}"
    >
      {{currentIndex === totalQuestions - 1 ? 'View My Style' : 'Continue'}}
    </button>
  </view>

  <!-- Loading -->
  <view class="loading" wx:if="{{loading}}">
    <text>Curating your style profile...</text>
  </view>
</view>
