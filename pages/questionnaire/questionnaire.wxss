.questionnaire-page {
  min-height: 100vh;
  background: var(--brand-bg);
  padding-bottom: 32rpx;
}

.progress-section {
  padding: 32rpx 32rpx 0;
  background: var(--brand-card);
}

.progress-bar {
  width: 100%;
  height: 6rpx;
  background: var(--brand-border);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--brand-black);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

.progress-text {
  text-align: center;
  padding: 12rpx 0 24rpx;
  font-size: 22rpx;
  color: var(--brand-light-gray);
  font-weight: 300;
}

.question-card {
  margin-top: 16rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.question-category {
  display: block;
  font-size: 22rpx;
  color: var(--brand-light-gray);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  font-weight: 300;
}

.question-text {
  display: block;
  font-size: 36rpx;
  font-weight: 400;
  color: var(--brand-black);
  line-height: 1.5;
  margin-bottom: 40rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
}

.option-chip {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx;
  background: var(--brand-bg);
  border: 1rpx solid var(--brand-border);
  border-radius: var(--brand-radius);
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.option-chip.selected {
  background: var(--brand-black);
  border-color: var(--brand-black);
}

.option-letter {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  background: var(--brand-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--brand-black);
  border: 1rpx solid var(--brand-border);
  transition: all 0.2s;
}

.option-chip.selected .option-letter {
  background: rgba(255,255,255,0.15);
  border-color: rgba(255,255,255,0.3);
  color: #ffffff;
}

.option-chip.selected .option-text {
  color: #ffffff;
}

.option-text {
  font-size: 28rpx;
  color: var(--brand-black);
  line-height: 1.4;
  transition: color 0.2s;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: var(--brand-gray);
  margin-top: 32rpx;
  font-weight: 300;
}

/* Complete */
.complete-card {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 24rpx;
}

.complete-title {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--brand-black);
}

.complete-desc {
  font-size: 26rpx;
  color: var(--brand-gray);
  font-weight: 300;
}

/* Navigation */
.nav-section {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
}

.nav-btn-back {
  flex: 0 0 200rpx;
}

.nav-btn-next {
  flex: 1;
}

.nav-btn-next[disabled] {
  opacity: 0.3;
}
