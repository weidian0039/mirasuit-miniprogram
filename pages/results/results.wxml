<!--pages/results/results.wxml-->
<view class="container">
  <!-- Loading State -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">Curating your style profile...</text>
  </view>

  <!-- Error State -->
  <view class="error" wx:if="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-message">{{error}}</text>
    <button class="btn-primary" bindtap="retryAnalysis">Retry</button>
  </view>

  <!-- Results Content -->
  <view class="results" wx:if="{{!loading && !error}}">
    <!-- Header -->
    <view class="results-header">
      <text class="results-title">Your Style Profile</text>
      <text class="results-subtitle">Personalized recommendations based on your personality</text>
    </view>

    <!-- Personality Summary -->
    <view class="card personality-summary" wx:if="{{personality}}">
      <view class="card-header">
        <text class="card-title">Personality</text>
      </view>
      <view class="personality-display">
        <view class="mbti-badge">
          <text class="mbti-type">{{personality.mbti.type}}</text>
          <text class="confidence">{{personality.mbti.confidence}}% match</text>
        </view>
        <view class="enneagram-badge">
          <text class="enneagram-type">Type {{personality.enneagram.type}}</text>
          <text class="confidence">{{personality.enneagram.confidence}}% confidence</text>
        </view>
      </view>
      <view class="traits-list">
        <text class="trait-tag" wx:for="{{personality.traits}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <!-- Style Inspiration Image -->
    <view class="card style-image-card" wx:if="{{!loading && !error}}">
      <view class="card-header">
        <text class="card-title">Style Inspiration</text>
      </view>

      <!-- Image Loading Skeleton -->
      <view class="image-skeleton" wx:if="{{imageLoading}}">
        <view class="skeleton-shimmer"></view>
        <text class="skeleton-text">Generating your inspiration...</text>
      </view>

      <!-- Image Display -->
      <view class="style-image-wrapper" wx:elif="{{styleImage}}">
        <image
          src="{{styleImage.imageUrl}}"
          mode="aspectFill"
          class="style-image"
          bindtap="previewImage"
          lazy-load="{{true}}"
        />
        <view class="image-badge" wx:if="{{styleImage.isFallback}}">
          <text class="badge-text">Preview</text>
        </view>
      </view>

      <!-- Image Actions -->
      <view class="image-actions" wx:if="{{styleImage}}">
        <button class="btn-icon" bindtap="previewImage" hover-class="btn-icon-active">
          <text class="btn-icon-text">Preview</text>
        </button>
        <button class="btn-icon" bindtap="saveImage" hover-class="btn-icon-active">
          <text class="btn-icon-text">Save</text>
        </button>
        <button class="btn-icon" bindtap="shareImage" hover-class="btn-icon-active">
          <text class="btn-icon-text">Share</text>
        </button>
      </view>
    </view>

    <!-- M-9: Style Video Section -->
    <view class="card style-video-card" wx:if="{{!loading && !error}}">
      <view class="card-header">
        <text class="card-title">Your Style in Motion</text>
        <text class="card-subtitle">15-second personalized style reveal</text>
      </view>

      <!-- Video Loading Skeleton -->
      <view class="video-skeleton" wx:if="{{videoLoading}}">
        <view class="skeleton-shimmer"></view>
        <view class="video-skeleton-play"></view>
        <text class="skeleton-text">Crafting your style video...</text>
      </view>

      <!-- Video Thumbnail Display -->
      <view class="style-video-wrapper" wx:elif="{{styleVideo}}">
        <image
          src="{{styleVideo.thumbnailUrl}}"
          mode="aspectFill"
          class="style-video-thumbnail"
          bindtap="previewStyleVideo"
          lazy-load="{{true}}"
        />
        <!-- Play indicator -->
        <view class="video-play-overlay" wx:if="{{styleVideo.videoUrl}}">
          <view class="play-button">
            <text class="play-icon">▶</text>
          </view>
        </view>
        <!-- Fallback badge -->
        <view class="video-badge" wx:if="{{styleVideo.isFallback}}">
          <text class="badge-text">Available soon</text>
        </view>
        <!-- Duration label -->
        <view class="video-duration" wx:if="{{styleVideo.duration}}">
          <text class="duration-text">{{styleVideo.duration}}s</text>
        </view>
      </view>

      <!-- No video yet (waiting for generation) -->
      <view class="video-placeholder" wx:elif="{{!videoLoading}}">
        <view class="video-placeholder-icon">
          <text class="placeholder-play">▶</text>
        </view>
        <text class="placeholder-text">Your style story is taking shape...</text>
      </view>

      <!-- Video Actions -->
      <view class="video-actions" wx:if="{{styleVideo}}">
        <button class="btn-icon" bindtap="previewStyleVideo" hover-class="btn-icon-active">
          <text class="btn-icon-text">{{styleVideo.videoUrl ? 'Play' : 'Preview'}}</text>
        </button>
        <button class="btn-icon" bindtap="saveStyleVideoThumbnail" hover-class="btn-icon-active">
          <text class="btn-icon-text">Save</text>
        </button>
        <button class="btn-icon" bindtap="shareStyleVideo" hover-class="btn-icon-active">
          <text class="btn-icon-text">Share</text>
        </button>
      </view>
    </view>

    <!-- Style Recommendations -->
    <view class="card style-recommendations" wx:if="{{recommendations}}">
      <view class="card-header">
        <text class="card-title">Recommended Style</text>
      </view>
      <view class="style-content">
        <view class="style-tags">
          <text class="style-tag" wx:for="{{recommendations.recommendedStyles}}" wx:key="index">{{item}}</text>
        </view>
        <view class="style-details">
          <view class="detail-row">
            <text class="detail-label">Colors</text>
            <text class="detail-value">{{recommendations.colorSuggestions.join(', ')}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">Fabrics</text>
            <text class="detail-value">{{recommendations.fabricPreferences.join(', ')}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">Fit</text>
            <text class="detail-value">{{recommendations.fitRecommendation}}</text>
          </view>
        </view>
        <view class="style-advice" wx:if="{{recommendations.styleAdvice}}">
          <text class="advice-text">{{recommendations.styleAdvice}}</text>
        </view>
      </view>
    </view>

    <!-- Personalized Advice -->
    <view class="card personalized-advice" wx:if="{{advice}}">
      <view class="card-header">
        <text class="card-title">Your Personalized Advice</text>
      </view>
      <view class="advice-content">
        <view class="advice-recommendation">
          <text class="recommendation-label">Recommendation</text>
          <text class="recommendation-text">{{advice.recommendation}}</text>
        </view>
        <view class="advice-rationale">
          <text class="rationale-label">Why This Works</text>
          <text class="rationale-text">{{advice.rationale}}</text>
        </view>
        <view class="advice-steps" wx:if="{{advice.keyConsiderations}}">
          <text class="steps-label">Key Considerations</text>
          <view class="steps-list">
            <text class="step-item" wx:for="{{advice.keyConsiderations}}" wx:key="index">• {{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Actions -->
    <view class="actions">
      <button class="btn-primary" bindtap="getMoreAdvice">Get More Advice</button>
      <button class="btn-secondary" bindtap="shareResults">Share Results</button>
      <button class="btn-outline" bindtap="goToProfile">View Profile</button>
    </view>
  </view>
</view>
