/* pages/results/results.wxss */

.container {
  min-height: 100vh;
  background-color: #fafafa;
  padding: 40rpx;
}

/* Loading State */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1a1a1a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 300;
}

/* Error State */
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  text-align: center;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.error-message {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
  font-weight: 300;
}

/* Results Header */
.results-header {
  text-align: center;
  margin: 60rpx 0;
}

.results-title {
  display: block;
  font-size: 48rpx;
  font-weight: 300;
  color: #1a1a1a;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.results-subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
  font-weight: 300;
  line-height: 1.6;
}

/* Cards */
.card {
  background: #fff;
  border-radius: 8rpx;
  padding: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

/* Personality Summary */
.personality-display {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.mbti-badge,
.enneagram-badge {
  flex: 1;
  padding: 32rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #333 100%);
  border-radius: 8rpx;
  text-align: center;
}

.mbti-type,
.enneagram-type {
  display: block;
  font-size: 36rpx;
  font-weight: 400;
  color: #fff;
  margin-bottom: 8rpx;
}

.confidence {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 300;
}

.traits-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trait-tag {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  font-weight: 300;
}

/* Style Recommendations */
.style-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.style-tag {
  padding: 12rpx 24rpx;
  background: #1a1a1a;
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 300;
}

.style-details {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 300;
}

.detail-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 400;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
}

.style-advice {
  padding: 24rpx;
  background: #f9f9f9;
  border-left: 4rpx solid #1a1a1a;
  border-radius: 4rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  font-weight: 300;
}

/* Personalized Advice */
.advice-content {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.advice-recommendation,
.advice-rationale,
.advice-steps {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.recommendation-label,
.rationale-label,
.steps-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.recommendation-text {
  font-size: 32rpx;
  color: #1a1a1a;
  line-height: 1.5;
  font-weight: 300;
}

.rationale-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  font-weight: 300;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step-item {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  font-weight: 300;
}

/* Style Image Card */
.style-image-card {
  overflow: hidden;
}

.image-skeleton {
  width: 100%;
  height: 480rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.skeleton-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
  animation: shimmer 1.5s infinite;
}

/* M-15: compositor-friendly — transform: translateX() avoids layout recalculation */
@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(200%); }
}

.skeleton-text {
  font-size: 24rpx;
  color: #999;
  font-weight: 300;
  letter-spacing: 1rpx;
  z-index: 1;
}

.style-image-wrapper {
  width: 100%;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.style-image {
  width: 100%;
  height: 480rpx;
  display: block;
  border-radius: 8rpx;
}

.image-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 4rpx;
  padding: 8rpx 16rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 300;
  letter-spacing: 1rpx;
}

.image-actions {
  display: flex;
  gap: 12rpx;
}

.btn-icon {
  flex: 1;
  height: 72rpx;
  border-radius: 4rpx;
  background: #f5f5f5;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon-active {
  background: #e8e8e8;
}

.btn-icon-text {
  font-size: 24rpx;
  color: #1a1a1a;
  font-weight: 300;
  letter-spacing: 1rpx;
}

/* Actions */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 40rpx 0;
}

.btn-primary,
.btn-secondary,
.btn-outline {
  font-size: 28rpx;
  font-weight: 300;
  letter-spacing: 1rpx;
  border-radius: 4rpx;
  padding: 24rpx;
  border: none;
}

.btn-primary {
  background-color: #1a1a1a;
  color: #fff;
}

.btn-secondary {
  background-color: #333;
  color: #fff;
}

.btn-outline {
  background-color: transparent;
  color: #1a1a1a;
  border: 1rpx solid #ddd;
}

.btn-primary:active,
.btn-secondary:active {
  opacity: 0.9;
}

.btn-outline:active {
  background-color: #f5f5f5;
}

/* M-9: Style Video Card */
.style-video-card {
  overflow: hidden;
}

.video-skeleton {
  width: 100%;
  height: 540rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.video-skeleton-play {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.video-skeleton-play::after {
  content: '';
  width: 0;
  height: 0;
  border-left: 24rpx solid rgba(0,0,0,0.3);
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  margin-left: 6rpx;
}

.style-video-wrapper {
  width: 100%;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.style-video-thumbnail {
  width: 100%;
  height: 540rpx;
  display: block;
  border-radius: 8rpx;
  background: #f0f0f0;
}

.video-play-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.2);
}

.play-button {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}

.play-icon {
  font-size: 36rpx;
  color: #1a1a1a;
  margin-left: 8rpx;
}

.video-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 4rpx;
  padding: 8rpx 16rpx;
}

.video-duration {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.6);
  border-radius: 4rpx;
  padding: 6rpx 12rpx;
}

.duration-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 300;
}

.video-placeholder {
  width: 100%;
  height: 540rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.video-placeholder-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.placeholder-play {
  font-size: 32rpx;
  color: rgba(255,255,255,0.7);
  margin-left: 6rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  font-weight: 300;
  letter-spacing: 1rpx;
}

.video-actions {
  display: flex;
  gap: 12rpx;
}

.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  font-weight: 300;
  margin-top: 8rpx;
  letter-spacing: 0.5rpx;
}
