.results-page {
  min-height: 100vh;
  background: var(--brand-bg);
  padding-bottom: 40rpx;
}

/* No Result */
.no-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 64rpx;
  text-align: center;
}

.no-result-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.no-result-title {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--brand-black);
  margin-bottom: 16rpx;
}

.no-result-desc {
  font-size: 26rpx;
  color: var(--brand-gray);
  margin-bottom: 48rpx;
  font-weight: 300;
}

/* Style Hero */
.style-hero {
  padding: 80rpx 32rpx 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16rpx;
}

.mbti-display {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.mbti-letter {
  font-size: 72rpx;
  font-weight: 200;
  color: rgba(255,255,255,0.9);
  letter-spacing: 8rpx;
  text-shadow: 0 2rpx 20rpx rgba(0,0,0,0.2);
}

.style-name {
  font-size: 44rpx;
  font-weight: 500;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.style-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 300;
}

/* Cards */
.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--brand-black);
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
  text-transform: uppercase;
}

.detail-card {
  margin-top: -60rpx;
  position: relative;
  z-index: 1;
}

.detail-text {
  font-size: 28rpx;
  color: var(--brand-gray);
  line-height: 1.8;
  font-weight: 300;
}

/* Recommendations */
.rec-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rec-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.rec-icon {
  flex-shrink: 0;
  font-size: 40rpx;
  width: 60rpx;
  height: 60rpx;
  background: var(--brand-bg);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rec-title {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: var(--brand-black);
  margin-bottom: 6rpx;
}

.rec-desc {
  display: block;
  font-size: 24rpx;
  color: var(--brand-gray);
  font-weight: 300;
  line-height: 1.5;
}

/* Color Palette */
.color-palette {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.color-swatch {
  flex: 1;
  min-width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.color-name {
  font-size: 18rpx;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.3);
}

/* Actions */
.actions-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* Image Preview */
.style-image {
  width: 100%;
  height: 600rpx;
  border-radius: var(--brand-radius);
  margin-bottom: 24rpx;
}
