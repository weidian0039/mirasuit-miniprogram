/* pages/home/home.wxss */

/* MIRASUIT Brand Colors */
page {
  background-color: #fafafa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.container {
  min-height: 100vh;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

/* Hero Section */
.hero {
  text-align: center;
  margin: 80rpx 0;
}

.brand-logo {
  font-size: 48rpx;
  font-weight: 300;
  letter-spacing: 8rpx;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.tagline {
  font-size: 28rpx;
  color: #666;
  font-weight: 300;
  letter-spacing: 1rpx;
}

/* Value Proposition */
.value-prop {
  text-align: center;
  margin: 60rpx 0;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 300;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  font-weight: 300;
  line-height: 1.6;
}

/* Action Section */
.action-section {
  margin: 60rpx 0;
  text-align: center;
}

.btn-primary {
  background-color: #1a1a1a;
  color: #fff;
  font-size: 32rpx;
  font-weight: 300;
  letter-spacing: 1rpx;
  border-radius: 4rpx;
  padding: 28rpx 60rpx;
  border: none;
  transition: all 0.3s ease;
}

.btn-primary:active {
  background-color: #333;
  transform: scale(0.98);
}

.hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
  font-weight: 300;
}

/* Features */
.features {
  margin: 60rpx 0;
}

.feature-item {
  text-align: center;
  margin: 40rpx 0;
  padding: 40rpx;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.feature-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.feature-title {
  display: block;
  font-size: 32rpx;
  font-weight: 400;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  font-weight: 300;
  line-height: 1.5;
}

/* Trust Indicators */
.trust {
  text-align: center;
  margin: 60rpx 0 20rpx;
}

.trust-text {
  font-size: 24rpx;
  color: #999;
  font-weight: 300;
  letter-spacing: 0.5rpx;
}
