.home-page {
  min-height: 100vh;
  background: var(--brand-bg);
  padding-bottom: 40rpx;
}

.hero {
  background: linear-gradient(135deg, #1a1a1a 0%, #3a3a3a 100%);
  padding: 80rpx 32rpx 120rpx;
  text-align: center;
}

.brand-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.brand-name {
  font-size: 64rpx;
  font-weight: 200;
  letter-spacing: 16rpx;
  color: #ffffff;
}

.brand-tagline {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-card {
  margin-top: -80rpx;
  position: relative;
  z-index: 1;
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  color: var(--brand-black);
  text-align: center;
  margin-bottom: 20rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: var(--brand-gray);
  text-align: center;
  line-height: 1.7;
  margin-bottom: 40rpx;
}

.mbti-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  background: var(--brand-bg);
  border-radius: 100rpx;
  margin-bottom: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-black);
  letter-spacing: 4rpx;
  border: 1rpx solid var(--brand-border);
}

.mbti-label {
  font-size: 24rpx;
  font-weight: 300;
  color: var(--brand-gray);
  letter-spacing: 2rpx;
}

.start-btn {
  margin-top: 16rpx;
}

.steps-card {
  margin-top: 0;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-black);
  text-align: center;
  letter-spacing: 2rpx;
  margin-bottom: 40rpx;
  text-transform: uppercase;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.step-num {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  background: var(--brand-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--brand-black);
  font-weight: 400;
  border: 1rpx solid var(--brand-border);
}

.step-content {
  flex: 1;
  padding-top: 10rpx;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: var(--brand-black);
  margin-bottom: 6rpx;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: var(--brand-gray);
  font-weight: 300;
  line-height: 1.5;
}

.privacy-note {
  padding: 32rpx;
  text-align: center;
}

.privacy-note text {
  font-size: 22rpx;
  color: var(--brand-light-gray);
  font-weight: 300;
  line-height: 1.6;
}
