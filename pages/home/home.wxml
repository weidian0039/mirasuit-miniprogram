<!--pages/home/home.wxml-->
<view class="container">
  <!-- Hero Section -->
  <view class="hero">
    <view class="brand-logo">MIRASUIT</view>
    <text class="tagline">AI-Powered Bespoke Menswear</text>
  </view>

  <!-- Value Proposition -->
  <view class="value-prop">
    <text class="title">Discover Your Style</text>
    <text class="subtitle">Personalized recommendations based on your personality</text>
  </view>

  <!-- Action Button -->
  <view class="action-section">
    <button class="btn-primary" bindtap="startAnalysis">
      Start Style Analysis
    </button>
    <text class="hint">Takes 2 minutes · No signup required</text>
  </view>

  <!-- Features Preview -->
  <view class="features">
    <view class="feature-item">
      <view class="feature-icon">🎯</view>
      <text class="feature-title">Personality Analysis</text>
      <text class="feature-desc">MBTI & Enneagram based insights</text>
    </view>

    <view class="feature-item">
      <view class="feature-icon">👔</view>
      <text class="feature-title">Style Recommendations</text>
      <text class="feature-desc">Tailored to your personality</text>
    </view>

    <view class="feature-item">
      <view class="feature-icon">✨</view>
      <text class="feature-title">Premium Quality</text>
      <text class="feature-desc">Bespoke menswear expertise</text>
    </view>
  </view>

  <!-- Trust Indicators -->
  <view class="trust">
    <text class="trust-text">Privacy-first · All data stored locally</text>
  </view>
</view>
