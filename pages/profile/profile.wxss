/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background-color: #fafafa;
  padding: 40rpx;
}

/* Profile Header */
.profile-header {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
  padding: 40rpx;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.avatar-section {
  margin-right: 32rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #333 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}

.profile-info {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: 400;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.completion {
  display: block;
  font-size: 26rpx;
  color: #999;
  font-weight: 300;
}

.completion.complete {
  color: #4caf50;
}

/* Cards */
.personality-card,
.style-card {
  background: #fff;
  border-radius: 8rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

/* Personality Types */
.personality-types {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-badge {
  flex: 1;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 4rpx;
  text-align: center;
}

.type-label {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  font-weight: 300;
}

.type-value {
  display: block;
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 400;
}

/* Traits */
.traits {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trait {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  font-weight: 300;
}

/* Style Details */
.style-details {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.style-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.style-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.style-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 300;
}

.style-value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 400;
}

/* Actions */
.actions {
  margin: 40rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-primary,
.btn-secondary,
.btn-outline {
  font-size: 28rpx;
  font-weight: 300;
  letter-spacing: 1rpx;
  border-radius: 4rpx;
  padding: 24rpx;
  border: none;
}

.btn-primary {
  background-color: #1a1a1a;
  color: #fff;
}

.btn-secondary {
  background-color: #333;
  color: #fff;
}

.btn-outline {
  background-color: transparent;
  color: #1a1a1a;
  border: 1rpx solid #ddd;
}

.btn-primary:active,
.btn-secondary:active {
  opacity: 0.9;
}

.btn-outline:active {
  background-color: #f5f5f5;
}

/* History Section */
.history-section {
  margin: 40rpx 0;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 400;
  color: #666;
  letter-spacing: 1rpx;
}

.history-list {
  background: #fff;
  border-radius: 8rpx;
  overflow: hidden;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-text {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 300;
}

.history-time {
  font-size: 22rpx;
  color: #999;
  font-weight: 300;
}

/* Privacy Notice */
.privacy-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 60rpx 0 20rpx;
  gap: 12rpx;
}

.privacy-icon {
  font-size: 28rpx;
}

.privacy-text {
  font-size: 24rpx;
  color: #999;
  font-weight: 300;
}

/* M-13 Alpha Feedback */
.feedback-section {
  display: flex;
  justify-content: center;
  margin: 20rpx 0 0;
}

.btn-feedback {
  font-size: 26rpx;
  font-weight: 300;
  color: #999;
  background: transparent;
  border: 1rpx solid #ddd;
  border-radius: 4rpx;
  padding: 16rpx 40rpx;
  letter-spacing: 1rpx;
}

.btn-feedback::after {
  border: none;
}

.feedback-thanks {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 300;
  margin-top: 20rpx;
  padding: 16rpx;
}

/* Feedback Modal Overlay */
.feedback-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.feedback-modal-content {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 48rpx 40rpx;
  overflow-y: auto;
}

.feedback-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.feedback-title {
  display: block;
  font-size: 36rpx;
  font-weight: 400;
  color: #1a1a1a;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.feedback-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  font-weight: 300;
}

/* Star Rating */
.rating-section {
  margin-bottom: 32rpx;
}

.rating-label,
.stage-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  font-weight: 300;
  margin-bottom: 16rpx;
}

.stars {
  display: flex;
  gap: 8rpx;
  justify-content: center;
}

.star {
  font-size: 52rpx;
  color: #ddd;
  line-height: 1;
  padding: 8rpx;
}

.star.active {
  color: #1a1a1a;
}

/* Stage Selector */
.stage-section {
  margin-bottom: 32rpx;
}

.stage-options {
  display: flex;
  gap: 16rpx;
}

.stage-chip {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 4rpx;
  font-weight: 300;
}

.stage-chip.active {
  background: #1a1a1a;
  color: #fff;
}

/* Comment */
.comment-section {
  margin-bottom: 24rpx;
  position: relative;
}

.comment-input {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 4rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 300;
  box-sizing: border-box;
  background: #fafafa;
  line-height: 1.6;
}

.char-count {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  font-size: 22rpx;
  color: #ccc;
  font-weight: 300;
}

/* Contact */
.contact-section {
  margin-bottom: 32rpx;
}

.contact-input {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 4rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 300;
  background: #fafafa;
  box-sizing: border-box;
}

/* Feedback Actions */
.feedback-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.btn-feedback-cancel,
.btn-feedback-submit {
  flex: 1;
  font-size: 28rpx;
  font-weight: 300;
  letter-spacing: 1rpx;
  padding: 24rpx;
  border-radius: 4rpx;
  border: none;
}

.btn-feedback-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-feedback-submit {
  background: #1a1a1a;
  color: #fff;
}

.btn-feedback-submit[disabled] {
  background: #ccc;
  color: #fff;
}
